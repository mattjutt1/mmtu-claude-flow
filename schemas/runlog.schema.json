{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Runlog Entry",
  "type": "object",
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "who": {
      "type": "string"
    },
    "what": {
      "type": "string"
    },
    "why": {
      "type": "string"
    },
    "where": {
      "type": "string"
    },
    "when": {
      "type": "string",
      "format": "date-time"
    },
    "how": {
      "type": "string"
    },
    "evidence": {
      "type": "string"
    },
    "tool_calls": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "tool_name": {
            "type": "string"
          },
          "tool_input": {
            "type": "object"
          },
          "tool_output": {
            "type": "object"
          }
        },
        "required": ["tool_name", "tool_input", "tool_output"]
      }
    }
  },
  "required": ["timestamp", "who", "what", "why", "where", "when", "how"]
}